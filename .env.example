# Copy this file to .env.local and fill in your values.
# Never commit .env.local or real credentials to source control.

# Google OAuth2 Client ID for Drive sync feature.
# Obtain from https://console.cloud.google.com/apis/credentials
# Add this as a GitHub Actions secret named TABNEST_OAUTH_CLIENT_ID for CI builds.
TABNEST_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com


# Google Extension Key
GOOGLE_EXTENSION_KEY=your-extension-key